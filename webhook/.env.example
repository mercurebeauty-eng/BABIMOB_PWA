# Supabase (BABIMOB_PWA)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# CinetPay — récupérés sur https://admin.cinetpay.com → Intégrations → Paramètres
CINETPAY_API_KEY=
CINETPAY_SITE_ID=

# URLs publiques du webhook (une fois déployé sur Railway)
# Format attendu :  https://<ton-service>.up.railway.app/cinetpay/notify
CINETPAY_NOTIFY_URL=https://babimob-webhook.up.railway.app/cinetpay/notify
CINETPAY_RETURN_URL=https://babimob-webhook.up.railway.app/cinetpay/return

# Port (Railway l'injecte automatiquement, mais on peut forcer en local)
PORT=3000
