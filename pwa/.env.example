# Supabase (projet BABIMOB_PWA — mêmes valeurs que le script d'ingestion,
# sauf qu'ici c'est la clé ANON, pas la service_role)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# URL de la PWA (nécessaire pour les redirects auth magic link)
# Dev : http://localhost:3000
# Prod Vercel : https://babimob-pwa.vercel.app (sans slash final)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Backends externes (déployés plus tard)
NEXT_PUBLIC_OTP_URL=https://babimob-otp.up.railway.app
NEXT_PUBLIC_WEBHOOK_URL=https://babimob-webhook.up.railway.app
